# Frontend (baked at Vite build time — use SmartSht LIVE keys for production builds)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# Optional; empty = same-origin /api via nginx or Vite proxy
VITE_AI_API_URL=

# Server
PORT=8787
HOST=127.0.0.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Ollama model id (intentional spelling — do not rename without recreating the model)
SMARTSHIT_MODEL=smartshit
# Finetuned excel-assist model (structured JSON output, better tool routing)
# Run: ollama create smartsht-assist -f server/Modelfile.excel-assist
SMARTSHT_ASSIST_MODEL=smartsht-assist
NUM_CTX=2048
NUM_PREDICT=512
CORS_ORIGIN=*

# Cloud AI providers (optional, recommended for production)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-32b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen3-32B
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Priority order for provider failover
LLM_PROVIDER_ORDER=openrouter,huggingface,groq,ollama

# Cloud Storage (RDS + S3) — required for cloud save, version history, sharing
# AWS resources are named "burntbeats" (recycled). SmartSht uses:
#   - `smartsht` schema within the `burntbeats` Postgres database
#   - `smartsht/` prefix within the `burntbeatz2-storage` S3 bucket
# Only DATABASE_URL is used by the server (not DB_HOST / DB_PORT / etc.)
DATABASE_URL=postgresql://user:password@host:5432/burntbeats?sslmode=require
S3_BUCKET=burntbeatz2-storage
S3_REGION=us-east-1
S3_SMARTSHT_PREFIX=smartsht
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy BurntBeats S3 vars — NOT used by smartsht server (safe to ignore):
# S3_ENABLED, S3_PREFIX=stems, S3_DELETE_LOCAL_AFTER_UPLOAD, DB_HOST, DB_PORT, DB_NAME, DB_USER

# Clerk Backend (SmartSht instance — clerk.smartsht.com / api.clerk.com)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
# Optional override if JWT issuer must be forced:
# CLERK_AUTHORIZED_PARTIES=https://smartsht.com,https://www.smartsht.com

# Stripe (LIVE for production — smartsht Pro $7/mo)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_1Tshf9P38C54URjEpxmSrir2
STRIPE_WEBHOOK_SECRET=whsec_...
APP_URL=https://smartsht.com
# Test-mode equivalents (local only): product prod_UqEjJmvd8TFLYq / price_1TqYGCP38C54URjEZIBJEXDU
# Webhooks: https://smartsht.com/api/stripe/webhook (live we_1TshfAP38C54URjEjGsP2IZB, test we_1TshewP38C54URjEFYjq3CMB)
